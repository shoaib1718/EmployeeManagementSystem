@model EmployeeManagementSystem.Models.Employee

<h2>Delete Employee</h2>

<h4>
    Are you sure you want to delete
    @Model.Name ?
</h4>

<form asp-action="Delete" method="post">

    <input type="hidden"
           asp-for="Id" />

    <button type="submit"
            class="btn btn-danger">
        Delete
    </button>

    <a asp-action="Index"
       class="btn btn-secondary">
        Cancel
    </a>

</form>